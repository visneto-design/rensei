{
  "name": "stl-screenshot",
  "version": "0.0.1",
  "type": "module",
  "description": "Screenshot STL files from multiple angles using Three.js WebGPU in Node.js",
  "bin": "dist/cli.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && pnpm build",
    "test": "vitest"
  },
  "keywords": [
    "stl",
    "screenshot",
    "3d",
    "webgpu",
    "three",
    "threejs",
    "render",
    "headless",
    "node",
    "cli"
  ],
  "dependencies": {
    "goke": "^6.8.0",
    "pngjs": "^7.0.0",
    "three": "^0.174.0",
    "webgpu": "^0.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.174.0"
  }
}
